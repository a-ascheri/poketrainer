# ── API base URL ──────────────────────────────────────────────────────────────
# Leave unset (or empty) to use the built-in Vite proxy (/api → localhost:8000).
# This is the recommended mode for both local dev and ngrok tunnels:
#   - Local:  http://localhost:5173  → proxy → http://localhost:8000
#   - ngrok:  https://xyz.ngrok-free.app → proxy → http://localhost:8000
#             (only ONE ngrok tunnel needed, for port 5173)
#
# Only set this explicitly if you need to reach a remote backend directly:
# VITE_API_BASE_URL=https://YOUR-BACKEND-ID.ngrok-free.app
