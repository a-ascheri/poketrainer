		{
			"name": "Authentication",
			"item": [
				{
					"name": "1. Generate PKCE Codes",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generar code_verifier aleatorio (43-128 caracteres)",
									"function generateCodeVerifier() {",
									"    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-._~';",
									"    let result = '';",
									"    for (let i = 0; i < 64; i++) {",
									"        result += chars.charAt(Math.floor(Math.random() * chars.length));",
									"    }",
									"    return result;",
									"}",
									"",
									"// Generar code_challenge usando S256",
									"async function generateCodeChallenge(verifier) {",
									"    const encoder = new TextEncoder();",
									"    const data = encoder.encode(verifier);",
									"    const digest = await crypto.subtle.digest('SHA-256', data);",
									"    const base64 = btoa(String.fromCharCode(...new Uint8Array(digest)));",
									"    return base64.replace(/\\+/g, '-').replace(/\\//g, '_').replace(/=+$/, '');",
									"}",
									"",
									"const codeVerifier = generateCodeVerifier();",
									"pm.collectionVariables.set('code_verifier', codeVerifier);",
									"",
									"generateCodeChallenge(codeVerifier).then(challenge => {",
									"    pm.collectionVariables.set('code_challenge', challenge);",
									"    console.log('Code Verifier:', codeVerifier);",
									"    console.log('Code Challenge:', challenge);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Este request genera automáticamente los códigos PKCE (code_verifier y code_challenge) y los guarda en las variables de colección. Ejecutar primero antes de Authorization."
					},
					"response": []
				},
				{
					"name": "2. Authorize (Get Authorization Code)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.code) {",
									"        pm.collectionVariables.set('authorization_code', response.code);",
									"        console.log('Authorization code guardado:', response.code);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/authorize?client_id=poketrainer-app&redirect_uri=http://localhost:3000/callback&code_challenge={{code_challenge}}&code_challenge_method=S256&username=testuser&password=testpassword123",
							"host": ["{{base_url}}"],
							"path": ["authorize"],
							"query": [
								{
									"key": "client_id",
									"value": "poketrainer-app",
									"description": "ID del cliente"
								},
								{
									"key": "redirect_uri",
									"value": "http://localhost:3000/callback",
									"description": "URL de redirección"
								},
								{
									"key": "code_challenge",
									"value": "{{code_challenge}}",
									"description": "Code challenge generado con S256"
								},
								{
									"key": "code_challenge_method",
									"value": "S256",
									"description": "Método de challenge"
								},
								{
									"key": "username",
									"value": "testuser",
									"description": "Nombre de usuario"
								},
								{
									"key": "password",
									"value": "testpassword123",
									"description": "Contraseña del usuario"
								}
							]
						},
						"description": "Endpoint de autorización OAuth2 con PKCE. Retorna un código de autorización."
					},
					"response": []
				},
				{
					"name": "3. Token (Exchange Code for Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    if (response.access_token) {",
									"        pm.collectionVariables.set('access_token', response.access_token);",
									"        console.log('Access token guardado');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "authorization_code",
									"description": "Tipo de grant"
								},
								{
									"key": "code",
									"value": "{{authorization_code}}",
									"description": "Código de autorización obtenido"
								},
								{
									"key": "redirect_uri",
									"value": "http://localhost:3000/callback",
									"description": "Debe coincidir con el usado en /authorize"
								},
								{
									"key": "client_id",
									"value": "poketrainer-app",
									"description": "ID del cliente"
								},
								{
									"key": "code_verifier",
									"value": "{{code_verifier}}",
									"description": "Code verifier original"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/token",
							"host": ["{{base_url}}"],
							"path": ["token"]
						},
						"description": "Intercambia el código de autorización por un access token JWT"
					},
					"response": []
				}
			],
			"description": "Flujo de autenticación OAuth2 con PKCE"
		},
